{
  "name": "@capire/sflight",
  "version": "1.0.0",
  "private": true,
  "description": "CAP flight demo scenario",
  "license": "SAP SAMPLE CODE LICENSE",
  "repository": "https://github.com/SAP-samples/cap-sflight",
  "engines": {
    "node": "^16 || ^18"
  },
  "scripts": {
    "lint": "npx eslint .",
    "start": "cds-serve",
    "test": "jest",
    "postinstall": "npm dedupe",
    "watch": "cds watch --production",
    "kill": "kill-port --port 4004",
    "cf_deploy": " mbt build -p=XSA -t=mta_archives",
    "build": "cds build --production --for hana --for node-cf",
    "test:mocha": "npx mocha --timeout 20000",
    "travel-processor": "cds watch --open travel_processor/webapp/index.html?sap-ui-xx-viewCache=false",
    "travel-analytics": "cds watch --open travel_analytics/webapp/index.html?sap-ui-xx-viewCache=false"
  },
  "dependencies": {
    "@sap/xssec": "^3.3.5",
    "@sap/xsenv": "^4.0.0",
    "@sap/cds": "^7.3.0",
    "@sap/cds-dk": "^7.3.0",
    "@sap/cds-fiori": "^1.1.0",
    "@sap/cds-hana": "^2.0.0",
    "@sap/hdi-deploy": "^4.8.2",
    "@sap/hdbext": "^8.0.0",
    "@sap/hana-client": "^2.18.24",
    "@sap/ux-specification": "^1.108.16",
    "passport": "^0.6.0",
    "express": "^4.18.2",
    "axios": "^1.5.1"
  },
  "devDependencies": {
    "@cap-js/cds-typer": "^0.11.1",
    "chai": "^4.3.10",
    "@types/node": "^20.6.0",
    "@types/sap__xsenv": "^3.3.0",
    "kill-port": "^2.0.1",
    "make": "^0.8.1",
    "mbt": "^1.2.25",
    "chai-as-promised": "^7.1.1",
    "chai-subset": "^1.6.0",
    "cross-spawn": "^7.0.3",
    "http-proxy": "^1.18.1",
    "jest": "^29.0.2",
    "qunit": "^2.9.3",
    "sqlite3": "^5.1.6"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "hana",
        "model": [
          "db/",
          "srv/"
        ]
      },
      "[production]": {
        "db": {
          "kind": "hana-cloud"
        },
        "auth": {
          "kind": "xsuaa"
        }
      },
      "[development]": {
        "db": {
          "kind": "sqlite"
        },
        "auth": {
          "kind": "mocked-auth",
          "users": {
            "rose": {
              "roles": []
            },
            "martha": {
              "roles": [
                "reviewer"
              ]
            },
            "amy": {
              "roles": [
                "processor"
              ]
            },
            "admin": {
              "password": "admin",
              "roles": [
                "admin"
              ]
            }
          }
        }
      }
    },
    "log": {
      "service": true
    },
    "features": {
      "odata_new_parser": true
    },
    "build": {
      "[node]": {
        "target": "gen",
        "tasks": [
          {
            "for": "node-cf"
          },
          {
            "for": "hana"
          }
        ]
      },
      "[java]": {
        "target": ".",
        "tasks": [
          {
            "for": "java-cf"
          }
        ]
      },
      "[hana]": {
        "target": "gen",
        "tasks": [
          {
            "for": "hana"
          }
        ]
      }
    }
  },
  "files": [
    "db/",
    "srv/",
    "app/",
    "package.json",
    "package-lock.json",
    "README.md",
    "LICENSE"
  ],
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 20000
  },
  "sapux": [
    "app/travel_processor",
    "app/travel_analytics"
  ]
}
